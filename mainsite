<script>
/* ===================== STARFIELD ===================== */
(function(){
  const canvas = document.getElementById('starfield');
  const ctx = canvas.getContext('2d');
  let w,h,stars;
  function resize(){
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
    stars = [];
    const count = Math.floor((w*h)/4000);
    for(let i=0;i<count;i++){
      stars.push({
        x: Math.random()*w,
        y: Math.random()*h,
        r: Math.random()*1.4 + 0.2,
        baseAlpha: Math.random()*0.6+0.2,
        speed: Math.random()*0.15+0.02,
        phase: Math.random()*Math.PI*2
      });
    }
  }
  window.addEventListener('resize', resize);
  resize();

  let scrollY = 0;
  window.addEventListener('scroll', ()=>{ scrollY = window.scrollY; }, {passive:true});

  function draw(t){
    ctx.clearRect(0,0,w,h);
    ctx.fillStyle = '#05070F';
    ctx.fillRect(0,0,w,h);
    for(const s of stars){
      const twinkle = Math.sin(t*0.001*s.speed*10 + s.phase)*0.3 + 0.7;
      const parallaxY = (s.y + scrollY*0.05*s.r) % h;
      ctx.beginPath();
      ctx.arc(s.x, parallaxY, s.r, 0, Math.PI*2);
      ctx.fillStyle = `rgba(231,236,251,${s.baseAlpha*twinkle})`;
      ctx.fill();
    }
    requestAnimationFrame(draw);
  }
  draw(0);
})();

/* ===================== HERO ROUTE CONSTELLATION ===================== */
(function(){
  const canvas = document.getElementById('route-canvas');
  const ctx = canvas.getContext('2d');
  let w,h,nodes,t=0;

  function resize(){
    const rect = canvas.parentElement.getBoundingClientRect();
    w = canvas.width = rect.width;
    h = canvas.height = rect.height;
    nodes = [];
    const n = 8;
    for(let i=0;i<n;i++){
      nodes.push({
        x: Math.random()*w*0.8 + w*0.1,
        y: Math.random()*h*0.8 + h*0.1,
        r: Math.random()*3+2,
        pulse: Math.random()*Math.PI*2
      });
    }
  }
  window.addEventListener('resize', resize);
  resize();

  function draw(){
    t += 0.01;
    ctx.clearRect(0,0,w,h);

    // connections
    for(let i=0;i<nodes.length;i++){
      for(let j=i+1;j<nodes.length;j++){
        const a=nodes[i], b=nodes[j];
        const dist = Math.hypot(a.x-b.x, a.y-b.y);
        if(dist < w*0.45){
          ctx.beginPath();
          ctx.moveTo(a.x,a.y);
          ctx.lineTo(b.x,b.y);
          const alpha = 0.12 * (1 - dist/(w*0.45));
          ctx.strokeStyle = `rgba(62,230,224,${alpha})`;
          ctx.lineWidth = 1;
          ctx.stroke();

          // traveling pulse
          const prog = (t*0.3 + i*0.13 + j*0.07) % 1;
          const px = a.x + (b.x-a.x)*prog;
          const py = a.y + (b.y-a.y)*prog;
          ctx.beginPath();
          ctx.arc(px,py,1.6,0,Math.PI*2);
          ctx.fillStyle = `rgba(255,90,31,${0.5*(1-dist/(w*0.45))})`;
          ctx.fill();
        }
      }
    }

    // nodes
    for(const node of nodes){
      const pulse = Math.sin(t*1.5+node.pulse)*0.5+0.5;
      const glowR = node.r + pulse*4;
      const grad = ctx.createRadialGradient(node.x,node.y,0,node.x,node.y,glowR*4);
      grad.addColorStop(0, 'rgba(62,230,224,0.5)');
      grad.addColorStop(1, 'rgba(62,230,224,0)');
      ctx.beginPath();
      ctx.arc(node.x,node.y,glowR*4,0,Math.PI*2);
      ctx.fillStyle = grad;
      ctx.fill();

      ctx.beginPath();
      ctx.arc(node.x,node.y,node.r,0,Math.PI*2);
      ctx.fillStyle = '#F4D9A8';
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }
  draw();
})();

/* ===================== SCROLL REVEAL ===================== */
(function(){
  const observer = new IntersectionObserver((entries)=>{
    entries.forEach(entry=>{
      if(entry.isIntersecting){
        entry.target.classList.add('visible');
      }
    });
  },{threshold:0.15});
  document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));
})();

/* ===================== WAYFINDER AI ===================== */
const wfResponses = [
  {keys:['fulfillment','shipping','order','warehouse'], reply:"Fulfillment is one of our core services — we handle order management end-to-end so you never touch a warehouse. Head to the Solutions section, or jump straight to Services.", link:"#solutions"},
  {keys:['ai','insight','data','analytic'], reply:"Our AI-Powered Insights turn your store data into decisions — demand forecasting, customer behavior, campaign performance. Check out the Solutions section below.", link:"#solutions"},
  {keys:['web','site','design','develop','storefront'], reply:"Managed Web Development is part of our Why Choose Us lineup — custom storefronts, built and maintained for you. Scroll to 'Why Choose Us' for details.", link:"#why-us"},
  {keys:['social','influencer','marketing'], reply:"Social Commerce Integration connects your store to social platforms and influencer partnerships for organic growth. See it under Solutions.", link:"#solutions"},
  {keys:['start','begin','sign up','contact','pricing','cost'], reply:"Ready to launch? Head to the Get Started section at the bottom of the page — our team will set up a call to map your route.", link:"#contact"},
  {keys:['about','who','mission','vision','story'], reply:"Seascape Commerce launched in 2025 to simplify e-commerce for entrepreneurs. Our full story is in the 'Evolution' section.", link:"#journey"},
  {keys:['hi','hello','hey'], reply:"Hello! I can route you to fulfillment, AI insights, web development, marketing, or help you get started. What's on your mind?"}
];

function wfPushMsg(text, who){
  const box = document.getElementById('wf-messages');
  const div = document.createElement('div');
  div.className = 'msg ' + who;
  div.textContent = text;
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
}

function wfRespond(query){
  const lower = query.toLowerCase();
  let match = wfResponses.find(r=>r.keys.some(k=>lower.includes(k)));
  setTimeout(()=>{
    if(match){
      wfPushMsg(match.reply, 'bot');
      if(match.link){
        setTimeout(()=>{
          document.querySelector(match.link)?.scrollIntoView({behavior:'smooth'});
        }, 600);
      }
    } else {
      wfPushMsg("I'm still learning that one — but I can help with fulfillment, AI insights, web development, marketing, or getting started. Try one of the quick options below!", 'bot');
    }
  }, 500);
}

function wfAsk(text){
  document.getElementById('wayfinder').classList.add('open');
  wfPushMsg(text, 'user');
  wfRespond(text);
}

function wfSend(){
  const input = document.getElementById('wf-input');
  const val = input.value.trim();
  if(!val) return;
  wfPushMsg(val, 'user');
  wfRespond(val);
  input.value = '';
}

/* ===================== STATS COUNTER ===================== */
(function(){
  const statEls = document.querySelectorAll('.stat-num');
  const observer = new IntersectionObserver((entries)=>{
    entries.forEach(entry=>{
      if(entry.isIntersecting){
        const el = entry.target;
        const target = parseInt(el.dataset.target, 10);
        let current = 0;
        const step = Math.max(1, Math.ceil(target/40));
        const timer = setInterval(()=>{
          current += step;
          if(current >= target){ current = target; clearInterval(timer); }
          el.textContent = current;
        }, 30);
        observer.unobserve(el);
      }
    });
  },{threshold:0.4});
  statEls.forEach(el=>observer.observe(el));
})();
</script>


